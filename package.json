{
  "name": "sanemd",
  "module": "src/sanemd.tsx",
  "type": "module",
  "private": true,
  "bin": {
    "sanemd": "./src/sanemd.tsx"
  },
  "scripts": {
    "start": "bun index.ts",
    "test": "FORCE_COLOR=3 bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "update-parsers": "bun ./node_modules/@opentui/core/lib/tree-sitter/update-assets.js --config ./parsers-config.json --assets ./assets/parsers --output /tmp/parsers-generated.ts"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "beautiful-mermaid": "^0.1.3",
    "marked": "15",
    "react": "^19.2.7"
  }
}
