{
  "name": "viewmd-cli",
  "version": "0.3.0",
  "description": "Interactive terminal markdown viewer with mermaid diagrams, syntax highlighting, and a less-style pager.",
  "license": "MIT",
  "author": "Elliot DeNolf",
  "homepage": "https://github.com/denolfe/viewmd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/denolfe/viewmd.git"
  },
  "bugs": {
    "url": "https://github.com/denolfe/viewmd/issues"
  },
  "keywords": [
    "markdown",
    "terminal",
    "tui",
    "cli",
    "viewer",
    "pager",
    "mermaid",
    "opentui"
  ],
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "viewmd": "./bin/viewmd.cjs"
  },
  "scripts": {
    "start": "bun index.ts",
    "test": "FORCE_COLOR=3 bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "release": "bun run scripts/release.ts",
    "build:bin": "bun run scripts/build-bin.ts",
    "build:npm": "bun run scripts/build-npm.ts",
    "stage:prebuilt": "bun run scripts/stage-prebuilt-npm.ts",
    "smoke": "bun run scripts/smoke-prebuilt.ts",
    "smoke:bin": "bun run scripts/smoke-bin.ts",
    "update-parsers": "bun ./node_modules/@opentui/core/lib/tree-sitter/update-assets.js --config ./parsers-config.json --assets ./assets/parsers --output /tmp/parsers-generated.ts"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/semver": "^7.7.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.1",
    "semver": "^7.8.5"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1",
    "@opentui/react": "^0.4.1",
    "beautiful-mermaid": "^0.1.3",
    "marked": "15",
    "react": "^19.2.7"
  }
}
